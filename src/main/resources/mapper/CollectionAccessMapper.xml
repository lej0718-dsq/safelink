<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dsqd.amc.linkedmo.mapper.CollectionAccessMapper">

    <resultMap id="AccessCountResultMap" type="com.dsqd.amc.linkedmo.model.CollectionAccessCount">
        <id column="id" property="id" />
        <result column="page" property="page" />
        <result column="description" property="description" />
        <result column="count" property="count" />
        <result column="log_month" property="logMonth" />
        <result column="collected_at" property="collectedAt" />
    </resultMap>

    <resultMap id="AccessPageResultMap" type="com.dsqd.amc.linkedmo.model.CollectionAccessPage">
        <id column="id" property="id" />
        <result column="page" property="page" />
        <result column="description" property="description" />
        <result column="status" property="status" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 접속 통계 전체 조회 -->
    <select id="getAllAccessCounts" resultMap="AccessCountResultMap">
        SELECT * FROM collection_access_count
        ORDER BY log_month DESC, count DESC
    </select>

    <!-- 접속 통계 조건 조회 -->
    <select id="searchAccessCounts" resultMap="AccessCountResultMap">
        SELECT * FROM collection_access_count
        WHERE 1=1
        <if test="logMonth != null and logMonth != ''">
            AND log_month = #{logMonth}
        </if>
        <if test="page != null and page != ''">
            AND page = #{page}
        </if>
        ORDER BY log_month DESC, count DESC
    </select>

    <!-- 집계 대상 페이지 전체 조회 -->
    <select id="getAllAccessPages" resultMap="AccessPageResultMap">
        SELECT * FROM collection_access_page
        ORDER BY id ASC
    </select>

    <!-- 활성 상태 페이지만 조회 -->
    <select id="getActiveAccessPages" resultMap="AccessPageResultMap">
        SELECT * FROM collection_access_page
        WHERE status = 1
        ORDER BY id ASC
    </select>

    <!-- 페이지 ID로 조회 -->
    <select id="getAccessPageById" resultMap="AccessPageResultMap">
        SELECT * FROM collection_access_page WHERE id = #{id}
    </select>

    <!-- 집계 대상 페이지 등록 -->
    <insert id="insertAccessPage">
        INSERT INTO collection_access_page (page, description, status)
        VALUES (#{page}, #{description}, #{status})
    </insert>

    <!-- 집계 대상 페이지 수정 -->
    <update id="updateAccessPage">
        UPDATE collection_access_page
        SET page = #{page},
            description = #{description},
            status = #{status}
        WHERE id = #{id}
    </update>

</mapper>